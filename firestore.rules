rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 로그인 여부 확인 함수
    function isSignedIn() {
      return request.auth != null;
    }

    // 모든 경로에 대해 로그인한 사용자만 허용
    // (DocumentPage가 이제 인증 토큰을 보내므로 정상 작동합니다)
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}