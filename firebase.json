{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "apphosting": [
    {
      "backendId": "studio",
      "rootDir": "./",
      "ignore": [
        "node_modules",
        ".git",
        ".agents",
        ".idx",
        ".next",
        ".vscode",
        "*.log",
        "*.txt",
        ".env"
      ],
      "alwaysDeployFromSource": true
    }
  ]
}
